# Authentication Configuration
# Copy this file to .env and update the values as needed

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
JWT_ISSUER=sn-clinic
JWT_AUDIENCE=sn-clinic-users

# Cookie Names (optional - defaults provided)
AUTH_JWT_COOKIE_NAME=next-auth.jwt-token
AUTH_SESSION_COOKIE_NAME=next-auth.session-token

# Session Configuration
SESSION_EXPIRES_IN=7d
SESSION_SAME_SITE=lax

# Security Configuration
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15
PASSWORD_MIN_LENGTH=8
REQUIRE_STRONG_PASSWORD=false

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/sn_clinic"

# Redis Configuration (if using Redis for sessions)
REDIS_URL="redis://localhost:6379"

# Google Drive Configuration (for backup features)
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Application Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
