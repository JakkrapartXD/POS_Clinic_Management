generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  role           String // admin, doctor, cashier, staff
  email          String          @unique
  username       String          @unique
  password_hash  String
  status         String          @default("active")
  avatar_url     String?         // URL สำหรับรูปโปรไฟล์
  avatar_path    String?         // Path ไฟล์ในเครื่อง
  isDelete       Boolean         @default(false)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  sessions       Session[]
  accounts       Account[]
  medicalRecords MedicalRecord[] @relation("UserMedicalRecords")
  appointments   Appointment[]   @relation("DoctorAppointments")
  purchases      Purchase[]
  orders         Order[]
  treatmentPlans TreatmentPlan[]
}

model Patient {
  id             String          @id @default(cuid())
  first_name     String
  last_name      String
  date_of_birth  DateTime?
  gender         String?
  phone          String?
  email          String?
  address        String?
  photo_url      String?         // URL สำหรับรูปผู้ป่วย
  photo_path     String?         // Path ไฟล์ในเครื่อง
  isDelete       Boolean         @default(false)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  orders         Order[]
  treatmentPlans TreatmentPlan[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique  // หมวดหมู่สินค้า
  description String?            // คำอธิบาย
  code        String?   @unique  // รหัสหมวดหมู่ (nullable)
  isDelete    Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  
  // Relations
  products    Product[]
}

model Product {
  id                      String          @id @default(cuid())
  product_name            String
  product_type            String?
  generic_name            String?
  short_name              String?
  status                  String?         @default("active")
  vat_percent             Float?          @default(0)
  expiration_warning_date Int?
  sale_price              Float
  unit                    String?
  pack_size               String?
  reorder_point           Int?
  cost                    Float?
  sku                     String?         @unique
  barcode                 String?         @unique
  stock_quantity          Int             @default(0)
  volume                  Float?
  volume_unit             String?
  shelf_code              String?
  shelf_row               String?
  category                Category?       @relation(fields: [categoryId], references: [id])
  categoryId              String?
  symptom_category        String?
  license_number          String?
  dosage_unit             String?
  dosage                  String?
  times_per_day           Int?
  interval_hours          Int?
  before_meal             Boolean?
  after_meal              Boolean?
  after_meal_immediate    Boolean?
  morning                 String?
  noon                    String?
  evening                 String?
  before_bed              String?
  properties              String?
  usage_instruction       String?
  sale_note               String?
  purchase_note           String?
  image_url               String?         // URL สำหรับรูปสินค้า
  image_path              String?         // Path ไฟล์ในเครื่อง
  isDelete                Boolean         @default(false)
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt
  orderItems               OrderItem[]
  purchaseItems           PurchaseItem[]
  prescriptions           Prescription[]
  stocks                  Stock[]
  salesReports            SalesReport[]
  stockAlerts             StockAlert[]

  // Database indexes for better query performance
  @@index([status])
  @@index([categoryId])
  @@index([product_type])
  @@index([created_at])
  @@index([product_name])
  @@index([isDelete])
  @@index([status, categoryId])
  @@index([status, product_type])
  @@index([status, isDelete])
}

model Order {
  id           String      @id @default(cuid())
  user         User?       @relation(fields: [userId], references: [id])
  userId       String?
  patient      Patient?    @relation(fields: [patientId], references: [id])
  patientId    String?
  order_date   DateTime    @default(now())
  status       String?     @default("completed")
  total_amount Float?
  isDelete     Boolean     @default(false)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  orderItems   OrderItem[]
  payments     Payment[]
  invoice      Invoice?
  is_walkin    Boolean     @default(false)
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId   String
  quantity    Int
  unit_price  Float
  total_price Float
  // Store product name and unit for historical reference
  product_name String?
  product_unit String?
}

model Payment {
  id           String   @id @default(cuid())
  order        Order    @relation(fields: [orderId], references: [id])
  orderId      String
  payment_type String // cash, card, QR, insurance
  amount       Float
  payment_date DateTime @default(now())
  details      String?
  invoice      Invoice?
}

model Invoice {
  id             String   @id @default(cuid())
  order          Order    @relation(fields: [orderId], references: [id])
  orderId        String   @unique
  payment        Payment? @relation(fields: [paymentId], references: [id])
  paymentId      String?  @unique
  invoice_number String   @unique
  issued_at      DateTime @default(now())
  total_amount   Float
  createdByUserId String?
  created_by_username String?
}

model Supplier {
  id           String     @id @default(cuid())
  name         String
  contact_name String?
  phone        String?
  email        String?
  address      String?
  isDelete     Boolean    @default(false)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  purchases    Purchase[]
}

model Purchase {
  id            String         @id @default(cuid())
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  supplierId    String
  user          User?          @relation(fields: [userId], references: [id])
  userId        String?
  purchase_date DateTime       @default(now())
  total_amount  Float?
  status        String?        @default("received")
  isDelete      Boolean        @default(false)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  purchaseItems PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId  String
  quantity   Int
  unit_cost  Float
  total_cost Float
  // Store product name and unit for historical reference
  product_name String?
  product_unit String?
}

model Stock {
  id              String   @id @default(cuid())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId       String
  quantity        Int
  quantity_in     Int?
  is_outofstock   Boolean  @default(false)
  production_date DateTime?
  expiration_date DateTime?
  reference_table String?
  reference_id    String?
  note            String?
  created_at      DateTime @default(now())
  createdByUserId String?
  created_by_username String?
  product_name String?
  product_unit String?
}

model Appointment {
  id               String          @id @default(cuid())
  patient          Patient         @relation(fields: [patientId], references: [id])
  patientId        String
  doctor           User            @relation("DoctorAppointments", fields: [doctorId], references: [id])
  doctorId         String
  appointment_time DateTime
  status           String?         @default("scheduled")
  reason           String?
  isDelete         Boolean         @default(false)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  medicalRecords   MedicalRecord[]
}

model MedicalRecord {
  id            String         @id @default(cuid())
  patient       Patient        @relation(fields: [patientId], references: [id])
  patientId     String
  doctor        User           @relation("UserMedicalRecords", fields: [doctorId], references: [id])
  doctorId      String
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  appointmentId String?
  symptoms      String?
  diagnosis     String?
  treatment     String?
  notes         String?
  isDelete      Boolean        @default(false)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  prescriptions Prescription[]
}

model Prescription {
  id              String        @id @default(cuid())
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  medicalRecordId String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId       String
  dosage          String?
  dosage_unit     String?
  times_per_day   Int?
  duration_days   Int?
  instructions    String?
  // Store product name and unit for historical reference
  product_name String?
  product_unit String?
}

model TreatmentPlan {
  id           String    @id @default(cuid())
  patient      Patient   @relation(fields: [patientId], references: [id])
  patientId    String
  doctor       User      @relation(fields: [doctorId], references: [id])
  doctorId     String
  plan_details String?
  start_date   DateTime?
  end_date     DateTime?
  isDelete     Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

model DailyReport {
  id             String   @id @default(cuid())
  report_date    DateTime
  total_sales    Float?
  total_orders   Int?
  total_patients Int?
  created_at     DateTime @default(now())
  createdByUserId String?
  created_by_username String?
}

model StockAlert {
  id            String   @id @default(cuid())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId     String
  alert_type    String?
  alert_message String?
  created_at    DateTime @default(now())
  createdByUserId String?
  created_by_username String?
  acknowledged  Boolean  @default(false) // บันทึกว่ามีการรับทราบแล้วหรือไม่
  acknowledged_at DateTime?
  // Store product name and unit for historical reference
  product_name String?
  product_unit String?
}

model SalesReport {
  id            String   @id @default(cuid())
  report_date   DateTime
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId     String
  quantity_sold Int?
  total_sales   Float?
  created_at    DateTime @default(now())
  createdByUserId String?
  created_by_username String?
  // Store product name and unit for historical reference
  product_name String?
  product_unit String?
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  expires      DateTime
}

model Account {
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}
