{
  "name": "clinic-system-automated-tests",
  "version": "1.0.0",
  "description": "Automated test suite for Clinic Management System",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=mock.test",
    "test:integration": "jest --testPathPattern=mock.test",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --config=desktop-only.config.ts",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:safari": "playwright test --project=webkit",
    "test:e2e:edge": "playwright test --project='Microsoft Edge'",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e:desktop",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "setup": "node scripts/setup-test-env.js",
    "cleanup": "node scripts/cleanup-test-data.js"
  },
  "keywords": [
    "testing",
    "automation",
    "clinic",
    "medical",
    "system"
  ],
  "author": "Clinic System Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "faker": "^6.6.6",
    "jest": "^29.7.0",
    "moment": "^2.29.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "prisma": "^6.16.3"
  }
}
